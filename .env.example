# Solana RPC endpoint (e.g. Helius, Quicknode, Triton, etc.)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY_HERE

# Your Solana wallet address (must match the Ledger derivation path)
WALLET_ADDRESS=YourSolanaWalletAddressHere

# Raydium CLMM pool ID to range
POOL_ID=BZtgQEyS6eXUXicYPHecYQ7PybqodXQMvkjUbP4R8mUU

# Token mints (defaults are USDC/USDT)
MINT_A=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
MINT_B=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# Ledger derivation path
LEDGER_PATH=44'/501'

# Check interval in milliseconds (default: 60000)
CHECK_INTERVAL_MS=60000

# Rebalance residual threshold in USD (default: 1.0)
REBALANCE_RESIDUAL_USD=1.0

# Minimum SOL balance in lamports to keep for rent (default: 35000000 = 0.035 SOL)
MIN_SOL_LAMPORTS=35000000

